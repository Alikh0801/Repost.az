{
  "redirects": [
    {
      "source": "/category/:legacyId/pg/:page",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/category/:legacyId",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/news/:legacyPostId",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/home",
      "destination": "/",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://repost-api-cv3y.onrender.com/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://repost-api-cv3y.onrender.com/uploads/:path*"
    },
    {
      "source": "/sitemap.xml",
      "destination": "https://repost-api-cv3y.onrender.com/sitemap.xml"
    },
    {
      "source": "/robots.txt",
      "destination": "https://repost-api-cv3y.onrender.com/robots.txt"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
