NODE_ENV=development
PORT=3000

# --- Verilənlər bazası (bulud, PC-yə PostgreSQL quraşdırmayın) ---
# Supabase: Connect → ORMs → Prisma (iki sətir — kopyala)
# NestJS: hər ikisi Session pooler (5432). Edge/serverless üçün 6543 + pgbouncer=true
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require"
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require"

JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRES_IN=7d

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,https://your-app.vercel.app

# İlk admin (seed yalnız boş users cədvəlində işləyir)
SEED_ADMIN_EMAIL=admin@repost.az
SEED_ADMIN_PASSWORD=Admin123!

# Yüklənmiş şəkillərin URL prefiksi (local API)
PUBLIC_BASE_URL=http://localhost:3000

# İctimai sayt URL-i (sitemap, robots — sonunda / yox)
SITE_URL=http://localhost:5173

# Süni oxunuş artımı: dərcdən sonra VIEW_BOOST_WINDOW_HOURS saat, hər 5 dəq +10–20
VIEW_BOOST_ENABLED=true
VIEW_BOOST_INTERVAL_MS=300000
VIEW_BOOST_WINDOW_HOURS=6
VIEW_BOOST_MIN=10
VIEW_BOOST_MAX=20

# Tam bulud təlimatı: SETUP-CLOUD.md
